# Atlas Weather Intelligence Platform — environment configuration template
# Copy this file to .env and fill in real values. Never commit .env itself.

# --- Database ---
# Used by both the FastAPI app and docker-compose's postgres service.
POSTGRES_USER=atlas
POSTGRES_PASSWORD=changeme_local_dev_only
POSTGRES_DB=atlas
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://atlas:changeme_local_dev_only@db:5432/atlas

# --- OpenWeatherMap ---
# Free tier signup: https://openweathermap.org/api
# Provides: current weather, 5-day forecast, geocoding, and air pollution endpoints
# under the same key.
OPENWEATHERMAP_API_KEY=

# --- YouTube Data API v3 ---
# Free tier via Google Cloud Console: https://console.cloud.google.com/
# Enable "YouTube Data API v3" for your project, then create an API key.
YOUTUBE_API_KEY=

# --- Google Maps / Places API ---
# Same Google Cloud Console project as above; enable "Maps JavaScript API"
# and/or "Places API" depending on which surface you use.
GOOGLE_MAPS_API_KEY=

# --- Rest Countries API (v5) ---
# v1-v4 (incl. the old v3.1/alpha/{code} endpoint) were deprecated and shut
# down. v5 is the new long-term-stable version and requires a free API key
# (500 req/month, no credit card): https://restcountries.com/sign-up
REST_COUNTRIES_API_KEY=

# --- App config ---
APP_ENV=development
LOG_LEVEL=info

# --- Testing ---
# Used by pytest (see tests/conftest.py). Same credentials as above, but
# pointed at localhost since pytest runs on your host machine, not inside
# the docker network (where the hostname would be "db" instead).
TEST_DATABASE_URL=postgresql://atlas:changeme_local_dev_only@localhost:5432/atlas
